  "init": {
    "completed": false,
    "projectName": "My Project",
    "techStack": "",
    "features": [],
    "language": "zh-CN",
    "createdAt": ""
  },
  "skills": {
    "pipelineInit": { "enabled": true, "name": "pipeline-init" },
    "principles": { "enabled": true, "name": "coding-principles" },
    "safeTerminal": { "enabled": true, "name": "safe-terminal-executor" },
    "selfCheck": { "enabled": true, "name": "self-check" },
    "webTesting": { "enabled": true, "name": "web-testing" },
    "changelog": { "enabled": true, "name": "changelog" }
