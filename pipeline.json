    "antiBloat": {
      "enabled": true,
      "maxTotalRules": 30,
      "maxHardRules": 15,
      "maxObservations": 50,
      "retiredArchiveThreshold": 20,
      "softStalenessSessions": 10,
      "note": "Prevents context bloat. When limits hit, lowest-confidence rules demoted first. Stale SOFT rules demoted if not triggered in N sessions."
    },
